# ============================================================
# KisanVaani — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub
# ============================================================

# ── IBM Watson Speech-to-Text ───────────────────────────────
# Get from: cloud.ibm.com → Create resource → Speech to Text
IBM_STT_API_KEY=your_stt_api_key_here
IBM_STT_URL=https://api.au-syd.speech-to-text.watson.cloud.ibm.com
# Region options: us-south, eu-gb, au-syd, jp-tok

# ── IBM Watson Text-to-Speech ───────────────────────────────
# Get from: cloud.ibm.com → Create resource → Text to Speech
IBM_TTS_API_KEY=your_tts_api_key_here
IBM_TTS_URL=https://api.au-syd.text-to-speech.watson.cloud.ibm.com

# ── IBM Watson Language Translator ──────────────────────────
# Get from: cloud.ibm.com → Create resource → Language Translator
IBM_TRANSLATOR_API_KEY=your_translator_api_key_here
IBM_TRANSLATOR_URL=https://api.au-syd.language-translator.watson.cloud.ibm.com

# ── IBM watsonx.ai ───────────────────────────────────────────
# Get from: dataplatform.cloud.ibm.com → Create project → Settings
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── Twilio WhatsApp ──────────────────────────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# ── Supabase ─────────────────────────────────────────────────
# Get from: supabase.com/dashboard/project/kffmgwndqlmenfawebrq/settings/api
SUPABASE_URL=https://kffmgwndqlmenfawebrq.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── OpenWeatherMap ───────────────────────────────────────────
# Get from: openweathermap.org/api → Free tier
OPENWEATHER_API_KEY=your_owm_key_here

# ── Agmarknet / data.gov.in ──────────────────────────────────
# Get from: data.gov.in/user/register → My Account → API Keys
AGMARKNET_API_KEY=your_agmarknet_key_here

# ── Neo4j Aura ───────────────────────────────────────────────
# Get from: neo4j.com/cloud/aura-free → Create DB → Connection details
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ── App Settings ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
